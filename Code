<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Meine GitHub Website</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#0f172a;
    color:white;
}

nav{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px 10%;
    background:#111827;
}

.logo{
    font-size:24px;
    font-weight:bold;
}

nav ul{
    display:flex;
    list-style:none;
    gap:20px;
}

nav a{
    color:white;
    text-decoration:none;
}

.hero{
    height:90vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    text-align:center;
    padding:20px;
}

.hero h1{
    font-size:4rem;
    margin-bottom:20px;
}

.hero p{
    font-size:1.2rem;
    max-width:600px;
}

.btn{
    margin-top:25px;
    padding:12px 24px;
    background:#3b82f6;
    color:white;
    text-decoration:none;
    border-radius:8px;
}

.section{
    padding:80px 10%;
}

.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
    margin-top:30px;
}

.card{
    background:#1e293b;
    padding:25px;
    border-radius:12px;
}

footer{
    text-align:center;
    padding:20px;
    background:#111827;
}
</style>
</head>

<body>

<nav>
    <div class="logo">Meine Website</div>

    <ul>
        <li><a href="#home">Start</a></li>
        <li><a href="#leistungen">Leistungen</a></li>
        <li><a href="#kontakt">Kontakt</a></li>
    </ul>
</nav>

<section class="hero" id="home">
    <h1>Willkommen</h1>
    <p>Diese Website läuft direkt über GitHub Pages.</p>
    <a href="#leistungen" class="btn">Mehr erfahren</a>
</section>

<section class="section" id="leistungen">
    <h2>Leistungen</h2>

    <div class="cards">
        <div class="card">
            <h3>Webdesign</h3>
            <p>Moderne und responsive Webseiten.</p>
        </div>

        <div class="card">
            <h3>Programmierung</h3>
            <p>HTML, CSS und JavaScript Projekte.</p>
        </div>

        <div class="card">
            <h3>Support</h3>
            <p>Hilfe bei Webprojekten und Hosting.</p>
        </div>
    </div>
</section>

<section class="section" id="kontakt">
    <h2>Kontakt</h2>
    <p>E-Mail: deine@email.de</p>
</section>

<footer>
    © 2026 Meine GitHub Website
</footer>

</body>
</html>